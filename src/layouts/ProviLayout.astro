---
// src/layouts/TableLayout.astro
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/shared/admin/Sidebar.astro';
import TableActions from '../components/shared/admin/TableActions';
import { Icon } from 'astro-icon/components';

const { pageTitle } = Astro.props;
const currentPath = Astro.url.pathname;
const editPath = "/admin/formularioDVM";

const cellInputClass = "w-full bg-white border border-gray-300 rounded-md px-2 py-2 text-sm text-gray-700 outline-none";
---

<BaseLayout title={`${pageTitle} - Q-Vida Admin`}>
  <div class="flex min-h-screen bg-[#1c1c1c] font-sans">
    <Sidebar currentPath={currentPath} />

    <main class="flex-1 bg-[#e5e5e5] shadow-2xl flex flex-col overflow-hidden">
      
      <div class="bg-[#f0f0f0] px-6 py-4 border-b border-gray-300">
        <h1 class="text-xl font-medium text-gray-800">{pageTitle}</h1>
      </div>

      <div class="bg-[#bcbcbc] px-4 py-2 grid grid-cols-12 gap-4 items-center">
        <div class="col-span-1"></div>
        <div class="col-span-2 text-center text-xs text-gray-700 font-medium">Field</div>
        <div class="col-span-1 text-center text-xs text-gray-700 font-medium">Field</div>
        <div class="col-span-2 text-center text-xs text-gray-700 font-medium">Surnames</div>
        <div class="col-span-2 text-center text-xs text-gray-700 font-medium">Name</div>
        <div class="col-span-2 relative">
          <input type="text" placeholder="Search" class="w-full bg-[#f0f0f0] rounded px-2 py-1 text-[10px] outline-none" />
        </div>
        <div class="col-span-2"></div>
      </div>

      {/* Filas de la Tabla */}
      <div class="flex-grow overflow-auto p-0 space-y-1">
        {[1, 2, 3, 4].map((_) => (
          <div class="bg-white border-b border-gray-200 grid grid-cols-12 gap-4 items-center py-2 px-4">
            <div class="col-span-1"></div>
            <div class="col-span-2 px-1"><input type="text" class={cellInputClass} /></div>
            <div class="col-span-1 px-1"><input type="text" class={cellInputClass} /></div>
            <div class="col-span-2 px-1"><input type="text" class={cellInputClass} /></div>
            <div class="col-span-2 px-1"><input type="text" class={cellInputClass} /></div>
            <div class="col-span-4 flex justify-end">
                <TableActions client:load editPath={editPath} patientName="Juan Pérez">
                    <Icon name="heroicons:pencil" class="w-7 h-7 text-gray-600" slot="pencilIcon" />
                    <Icon name="heroicons:book-open" class="w-7 h-7 text-gray-600" slot="bookIcon" />
                </TableActions>
            </div>
          </div>
        ))}
      </div>

    </main>
  </div>
</BaseLayout>