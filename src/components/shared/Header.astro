---
// src/components/shared/Header.astro
const navLinks = [
  { text: 'Panel Cliente', href: '/client/login' },
  { text: 'Sobre nosotros', href: '#sobre-nosotros' },
  { text: 'Contactenos', href: '#contact' },
  { text: 'Info Legal', href: '#legal' },
  { text: 'Más', href: '#' },
];
---

<header class="w-full bg-white font-sans border-b border-gray-100">
  <div class="max-w-[1920px] mx-auto flex items-center h-28 px-8">
    
    <a href="/" class="flex-shrink-0">
      <img src="/img/Logo_Qvida.png" alt="Q-Vida Logo" class="h-16" />
    </a>

    <nav class="flex-grow flex justify-end items-center h-full">
      <ul class="flex items-center gap-4 h-full py-4"> {navLinks.map((link) => (
          <li class="h-full">
            <a 
              href={link.href} 
              class="flex items-center justify-center text-center h-full px-8 
                     bg-white text-gray-800 text-sm font-medium
                     shadow-[0px_4px_10px_rgba(0,0,0,0.1)] rounded-sm
                     hover:shadow-[0px_6px_15px_rgba(0,0,0,0.15)] 
                     hover:text-[#2eb0b0] transition-all duration-300 
                     min-w-[140px] leading-tight"
            >
              {link.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div>
</header>