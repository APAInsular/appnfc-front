---
// src/components/admin/MetricsCard.astro
import { Icon } from 'astro-icon/components';

const { title, value, subtext, color = "#2eb0b0", percentage = 0, iconName } = Astro.props;
---

<div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex flex-col gap-4 transition-all hover:shadow-md">
  <div class="flex items-start gap-4">
    <div class="p-3 rounded-xl" style={`background-color: ${color}15`}>
      <Icon name={`heroicons:${iconName}`} class="w-6 h-6" style={`color: ${color}`} />
    </div>
    
    <div class="flex-1">
      <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">{title}</h3>
      <div class="text-4xl font-bold text-gray-800 leading-tight">{value}</div>
      <p class="text-[10px] text-gray-400 mt-1 font-medium">{subtext}</p>
    </div>
  </div>

  {percentage > 0 && (
    /* Barra de progreso: Fondo ahora gris suave en lugar de bg-gray-800 */
    <div class="w-full bg-gray-100 h-1.5 rounded-full overflow-hidden mt-2">
      <div 
        class="h-full transition-all duration-700" 
        style={`width: ${percentage}%; background-color: ${color}`}
      ></div>
    </div>
  )}
</div>