---
// src/components/shared/Footer.astro
const footerLinks = [
  'Datos de contacto', 'Trabaja con nosotros', 'Blog', 'Información legal',
  'Accesibilidad', 'Condiciones de uso', 'Política de privacidad',
  'Política de cookies', 'Derechos de protección de datos'
];
---

<footer class="w-full bg-[#1c1d1e] text-[#dcdcdc] font-sans py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-8 items-end">
    
    <ul class="space-y-2">
      {footerLinks.map((link) => (
        <li class="flex items-center gap-2 text-sm">
          <span class="text-xs">•</span> {link}
        </li>
      ))}
    </ul>

    <div class="text-sm md:text-right">
      Platita © Todos los derechos reservados
    </div>

  </div>
</footer>