---
// src/components/shared/ContentBlock.astro
const { imageSrc, imageAlt, title, reverse = false } = Astro.props;
---

<section class={`flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-12 my-24`}>
  
  <div class="w-full md:w-1/2">
    <img 
      src={imageSrc} 
      alt={imageAlt} 
      class="w-full h-auto object-cover rounded-3xl shadow-xl" 
    />
  </div>

  <div class="w-full md:w-1/2 flex flex-col justify-center gap-6 px-4 md:px-0">
    {title && (
        <h2 class="text-4xl font-light text-gray-900 text-center md:text-left mb-4 uppercase tracking-widest">
            {title}
        </h2>
    )}
    <slot /> </div>

</section>