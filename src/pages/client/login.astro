---
import ClientLayout from "../../layouts/ClientLayout.astro";
import LoginForm from "../../components/forms/LoginForm";
---

<ClientLayout title="Inicio de Sesión - Q-Vida Care">
  <main class="min-h-screen flex items-center justify-center bg-white p-4">
    <div class="flex flex-col items-center gap-20 w-full">
      
      <img
        src="/img/Logo_Qvida.png"
        alt="Q-Vida Care Logo"
        class="w-full max-w-xl object-contain"
      />

      <LoginForm client:load />

    </div>
  </main>
</ClientLayout>

<style>
  main {
    font-family: 'Inter', sans-serif;
  }
</style>