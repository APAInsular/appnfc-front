---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/shared/admin/Sidebar.astro';
import MetricsCard from '../../components/shared/admin/MetricsCard.astro';
import { Icon } from 'astro-icon/components';

const title = "Metricas";
---

<BaseLayout title="Panel de Control - Q-Vida">
  <div class="flex min-h-screen bg-[#1c1c1c] font-sans">
    
    <Sidebar />

    <main class="flex-1 bg-[#1c1c1c] p-6 overflow-y-auto">
      
      <div class="bg-transparent h-full rounded-[40px] flex flex-col">
        
        <div class="flex justify-between items-center mb-10 px-4">
          <h1 class="text-2xl font-semibold text-white">{title}</h1>
          <div class="h-[1px] flex-grow mx-8 bg-gray-800"></div>
          <img src="/img/Logo_Qvida.png" alt="Logo" class="h-10 w-auto" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <MetricsCard 
            title="Pacientes Registrados" 
            value="1,247" 
            subtext="+23 este mes" 
            percentage={65} 
            iconName="users" 
          />
          <MetricsCard 
            title="Dispositivos en uso" 
            value="342" 
            subtext="87% de capacidad" 
            percentage={87} 
            iconName="device-tablet" 
          />
          <MetricsCard 
            title="Dispositivos Inhabilitados" 
            value="18" 
            subtext="En mantenimiento" 
            color="#f59e0b" 
            percentage={15} 
            iconName="exclamation-triangle" 
          />
        </div>

        <div class="bg-[#242424] p-8 rounded-2xl shadow-lg border border-white/5">
          <div class="flex items-center gap-3 mb-8">
            <Icon name="heroicons:bell" class="w-6 h-6 text-[#f59e0b]" />
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Gestión de Incidencias</h3>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-[#2a2a2a] p-6 rounded-2xl border-l-4 border-red-500 text-center">
              <p class="text-[10px] font-bold text-gray-500 uppercase mb-2">Incidencias Abiertas</p>
              <span class="text-5xl font-bold text-white">42</span>
            </div>
            <div class="bg-[#2a2a2a] p-6 rounded-2xl border-l-4 border-green-500 text-center">
              <p class="text-[10px] font-bold text-gray-500 uppercase mb-2">Incidencias Cerradas</p>
              <span class="text-5xl font-bold text-white">156</span>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>