---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LoginForm from "../../components/forms/LoginForm";
---

<BaseLayout title="Inicio de Sesión - Q-Vida Care">
  <div class="relative h-screen flex items-center justify-center overflow-hidden">
    
    <div class="absolute inset-0 -z-10 w-full h-full">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="100%"
        height="100%"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
        class="w-full h-full"
      >
        <polygon points="0,0 75,0 25,100 0,100" fill="#f5f5f6"></polygon>
        <polygon points="0,20 55,0 18,100 0,85" fill="#eeeeef"></polygon>
      </svg>
    </div>


    <LoginForm client:load isAdmin={true} /> {/* Cambiar a false en client/login.astro */}

  </div>
</BaseLayout>

<style>
  /* Aseguramos que el cuerpo no tenga overflow que corte las formas */
  :global(body) {
    overflow-x: hidden;
  }
</style>